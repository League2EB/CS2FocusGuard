<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="ShadowColor">#38000000</Color>

    <LinearGradientBrush x:Key="WindowBackgroundBrush"
                         StartPoint="0,0"
                         EndPoint="1,1">
        <GradientStop Offset="0" Color="#FFFAFBFE" />
        <GradientStop Offset="0.55" Color="#FFF0F4FA" />
        <GradientStop Offset="1" Color="#FFF7F9FD" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#E3E7EE" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#101828" />
    <SolidColorBrush x:Key="SettingTextBrush" Color="#172033" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#667085" />
    <SolidColorBrush x:Key="BodyTextBrush" Color="#475467" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#98A2B3" />
    <SolidColorBrush x:Key="DividerBrush" Color="#EAECF0" />
    <SolidColorBrush x:Key="AccentBrush" Color="#3771FF" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#2D62E6" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#2453C4" />
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ToggleOffBrush" Color="#CBD1DC" />
    <SolidColorBrush x:Key="ToggleKnobBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ControlHoverBrush" Color="#EEF4FF" />
    <SolidColorBrush x:Key="ControlPressedBrush" Color="#D1E0FF" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#D0D5DD" />
    <SolidColorBrush x:Key="InfoBackgroundBrush" Color="#EEF4FF" />
    <SolidColorBrush x:Key="InfoTextBrush" Color="#175CD3" />
    <SolidColorBrush x:Key="ItemIconBackgroundBrush" Color="#EAECF0" />
    <SolidColorBrush x:Key="ItemIconTextBrush" Color="#475467" />
    <SolidColorBrush x:Key="ListItemHoverBrush" Color="#F2F4F7" />
    <SolidColorBrush x:Key="ListItemSelectedBrush" Color="#E8EFFF" />
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#F2F4F7" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#C4CBD6" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#98A2B3" />
    <SolidColorBrush x:Key="NeutralStatusBrush" Color="#98A2B3" />
    <SolidColorBrush x:Key="WaitingStatusBrush" Color="#3771FF" />
    <SolidColorBrush x:Key="SuccessStatusBrush" Color="#12B76A" />
    <SolidColorBrush x:Key="WarningStatusBrush" Color="#F79009" />
    <SolidColorBrush x:Key="ErrorStatusBrush" Color="#F04438" />
</ResourceDictionary>
