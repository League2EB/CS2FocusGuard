<Window x:Class="CS2FocusGuard.App.UpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding AppTitle}"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI"
        FontSize="{DynamicResource Metric.Font.Body}"
        TextOptions.TextFormattingMode="Display">
    <Grid Width="{DynamicResource Metric.Dialog.ProgressWidth}"
          Height="{DynamicResource Metric.Dialog.ProgressHeight}"
          Margin="{DynamicResource Metric.Padding.Dialog}"
          UseLayoutRounding="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock FontSize="{DynamicResource Metric.Font.DialogTitle}"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Text="{Binding TitleText}" />
        <TextBlock x:Name="ProgressStatusText"
                   Grid.Row="1"
                   Margin="{DynamicResource Metric.Margin.ProgressStatus}"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   Text="{Binding StatusText}" />
        <ProgressBar x:Name="UpdateProgressBar"
                     Grid.Row="2"
                     Height="{DynamicResource Metric.Control.ProgressHeight}"
                     Margin="{DynamicResource Metric.Margin.ProgressBar}"
                     Minimum="0"
                     Maximum="100"
                     Value="{Binding ProgressPercent, Mode=OneWay}" />
        <Button x:Name="CancelButton"
                Grid.Row="3"
                Width="{DynamicResource Metric.Control.CancelButtonWidth}"
                Height="{DynamicResource Metric.Control.ButtonHeight}"
                Margin="{DynamicResource Metric.Margin.ProgressCancel}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Click="Cancel_Click"
                Content="{Binding CancelText}"
                IsEnabled="{Binding CanCancel}" />
    </Grid>
</Window>
