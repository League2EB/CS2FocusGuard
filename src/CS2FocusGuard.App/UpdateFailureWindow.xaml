<Window x:Class="CS2FocusGuard.App.UpdateFailureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding AppTitle}"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI"
        FontSize="{DynamicResource Metric.Font.Body}"
        TextOptions.TextFormattingMode="Display">
    <Grid Width="{DynamicResource Metric.Dialog.FailureWidth}"
          Height="{DynamicResource Metric.Dialog.FailureHeight}"
          Margin="{DynamicResource Metric.Padding.Dialog}"
          UseLayoutRounding="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock FontSize="{DynamicResource Metric.Font.DialogTitle}"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Text="{Binding TitleText}" />
        <TextBlock Grid.Row="1"
                   Margin="{DynamicResource Metric.Margin.DialogMessage}"
                   Foreground="{DynamicResource BodyTextBrush}"
                   Text="{Binding MessageText}"
                   TextWrapping="Wrap" />
        <TextBlock Grid.Row="2"
                   Margin="{DynamicResource Metric.Margin.ProgressStatus}"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   Text="{Binding FallbackText}"
                   TextWrapping="Wrap" />
        <TextBlock Grid.Row="3"
                   Margin="{DynamicResource Metric.Margin.ProgressStatus}"
                   Foreground="{DynamicResource MutedTextBrush}"
                   Text="{Binding LogText}"
                   TextTrimming="CharacterEllipsis"
                   ToolTip="{Binding LogText}" />
        <StackPanel Grid.Row="4"
                    Margin="{DynamicResource Metric.Margin.ProgressCancel}"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button x:Name="RetryButton"
                    Width="{DynamicResource Metric.Control.RetryButtonWidth}"
                    Height="{DynamicResource Metric.Control.ButtonHeight}"
                    Margin="{DynamicResource Metric.Margin.DialogButtonGap}"
                    Click="Retry_Click"
                    Content="{Binding RetryText}" />
            <Button x:Name="OpenReleasePageButton"
                    Width="{DynamicResource Metric.Control.ReleaseButtonWidth}"
                    Height="{DynamicResource Metric.Control.ButtonHeight}"
                    Margin="{DynamicResource Metric.Margin.DialogButtonGap}"
                    Click="OpenReleasePage_Click"
                    Content="{Binding OpenReleasePageText}"
                    Style="{DynamicResource PrimaryButton}" />
            <Button x:Name="CloseButton"
                    Width="{DynamicResource Metric.Control.LaterButtonWidth}"
                    Height="{DynamicResource Metric.Control.ButtonHeight}"
                    Click="Close_Click"
                    Content="{Binding CloseText}" />
        </StackPanel>
    </Grid>
</Window>
