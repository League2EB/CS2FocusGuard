<Window x:Class="CS2FocusGuard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:core="clr-namespace:CS2FocusGuard.Core;assembly=CS2FocusGuard.Core"
        mc:Ignorable="d"
        Title="{Binding AppTitle}"
        Width="620"
        Height="720"
        MinWidth="520"
        MinHeight="580"
        Icon="Assets/AppIcon.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F4F6FA"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="26" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Border x:Name="Track"
                                    Background="#CBD1DC"
                                    CornerRadius="13" />
                            <Ellipse x:Name="Knob"
                                     Width="20"
                                     Height="20"
                                     Margin="3"
                                     HorizontalAlignment="Left"
                                     Fill="White">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="4"
                                                      Direction="270"
                                                      Opacity="0.22"
                                                      ShadowDepth="1" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track"
                                        Property="Background"
                                        Value="#3771FF" />
                                <Setter TargetName="Knob"
                                        Property="HorizontalAlignment"
                                        Value="Right" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LanguageToggle" TargetType="CheckBox">
            <Setter Property="Width" Value="64" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border Background="#E3E7EE"
                                CornerRadius="13">
                            <Grid Margin="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="LanguageKnob"
                                        Background="White"
                                        CornerRadius="11"
                                        Grid.Column="1">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="4"
                                                          Direction="270"
                                                          Opacity="0.18"
                                                          ShadowDepth="1" />
                                    </Border.Effect>
                                </Border>
                                <TextBlock x:Name="ChineseLabel"
                                           Grid.Column="0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#667085"
                                           Text="中" />
                                <TextBlock x:Name="EnglishLabel"
                                           Grid.Column="1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#3771FF"
                                           Text="EN" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="LanguageKnob"
                                        Property="Grid.Column"
                                        Value="0" />
                                <Setter TargetName="ChineseLabel"
                                        Property="Foreground"
                                        Value="#3771FF" />
                                <Setter TargetName="EnglishLabel"
                                        Property="Foreground"
                                        Value="#667085" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#172033" />
        </Style>
        <Style x:Key="SettingDescription" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,4,20,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#667085" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="RefreshIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#EEF4FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#D1E0FF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <CheckBox HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Margin="0,7,12,0"
                  AutomationProperties.Name="{Binding LanguageToggleLabel}"
                  IsChecked="{Binding UseTraditionalChinese}"
                  Style="{StaticResource LanguageToggle}"
                  ToolTip="{Binding LanguageToggleLabel}" />
        <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="52" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Width="42"
                    Height="42"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="#3771FF"
                    CornerRadius="12">
                <Grid>
                    <Ellipse Width="17"
                             Height="17"
                             Stroke="White"
                             StrokeThickness="2" />
                    <Path Data="M 21,9 L 21,14 M 21,28 L 21,33 M 9,21 L 14,21 M 28,21 L 33,21"
                          Stroke="White"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" />
                </Grid>
            </Border>
            <StackPanel Grid.Column="1">
                <TextBlock FontSize="21"
                           FontWeight="SemiBold"
                           Foreground="#101828"
                           Text="{Binding AppTitle}" />
                <TextBlock Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="#667085"
                           Text="{Binding Subtitle}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,22,0,18"
                Padding="16,12"
                Background="White"
                BorderBrush="#E3E7EE"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="StatusDot"
                         Width="10"
                         Height="10"
                         Margin="0,0,10,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#98A2B3" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding State}"
                                             Value="{x:Static core:GuardState.Waiting}">
                                    <Setter Property="Fill" Value="#3771FF" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding State}"
                                             Value="{x:Static core:GuardState.Suppressed}">
                                    <Setter Property="Fill" Value="#12B76A" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding State}"
                                             Value="{x:Static core:GuardState.UserOverride}">
                                    <Setter Property="Fill" Value="#F79009" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding State}"
                                             Value="{x:Static core:GuardState.Error}">
                                    <Setter Property="Fill" Value="#F04438" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#344054"
                               Text="{Binding StatusLabel}" />
                    <TextBlock Margin="6,0,0,0"
                               FontSize="13"
                               Foreground="#667085"
                               Text="{Binding StatusText}" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="White"
                        BorderBrush="#E3E7EE"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="1" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="1" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Margin="18,13">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource SettingLabel}"
                                           Text="{Binding EnabledLabel}" />
                                <TextBlock Style="{StaticResource SettingDescription}"
                                           Text="{Binding EnabledDescription}" />
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      AutomationProperties.HelpText="{Binding EnabledDescription}"
                                      AutomationProperties.Name="{Binding EnabledLabel}"
                                      IsChecked="{Binding Enabled}"
                                      Style="{StaticResource ToggleSwitch}" />
                        </Grid>

                        <Border Grid.Row="1"
                                Margin="18,0"
                                Background="#EAECF0" />

                        <Grid Grid.Row="2" Margin="18,13">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource SettingLabel}"
                                           Text="{Binding StartWithWindowsLabel}" />
                                <TextBlock Style="{StaticResource SettingDescription}"
                                           Text="{Binding StartDescription}" />
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      AutomationProperties.HelpText="{Binding StartDescription}"
                                      AutomationProperties.Name="{Binding StartWithWindowsLabel}"
                                      IsChecked="{Binding StartWithWindows}"
                                      Style="{StaticResource ToggleSwitch}" />
                        </Grid>

                        <Border Grid.Row="3"
                                Margin="18,0"
                                Background="#EAECF0" />

                        <Grid Grid.Row="4" Margin="18,13">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource SettingLabel}"
                                           Text="{Binding CloseToTrayLabel}" />
                                <TextBlock Style="{StaticResource SettingDescription}"
                                           Text="{Binding CloseDescription}" />
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      AutomationProperties.HelpText="{Binding CloseDescription}"
                                      AutomationProperties.Name="{Binding CloseToTrayLabel}"
                                      IsChecked="{Binding CloseToTray}"
                                      Style="{StaticResource ToggleSwitch}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Margin="0,16,0,0"
                        Padding="18"
                        Background="White"
                        BorderBrush="#E3E7EE"
                        BorderThickness="1"
                        CornerRadius="14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SettingLabel}"
                                   Text="{Binding AudioAllowlistLabel}" />
                        <TextBlock Style="{StaticResource SettingDescription}"
                                   Text="{Binding AudioAllowlistDescription}" />

                        <Border Margin="0,12,0,0"
                                Padding="10,8"
                                Background="#EEF4FF"
                                CornerRadius="8">
                            <TextBlock FontSize="12"
                                       Foreground="#175CD3"
                                       Text="{Binding Cs2AlwaysAllowedText}" />
                        </Border>

                        <Grid Margin="0,14,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid>
                                <TextBox Height="36"
                                         Padding="11,7"
                                         VerticalContentAlignment="Center"
                                         AutomationProperties.Name="{Binding SearchApplicationsLabel}"
                                         BorderBrush="#D0D5DD"
                                         BorderThickness="1"
                                         Text="{Binding ApplicationSearch, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Foreground="#98A2B3"
                                           Text="{Binding SearchApplicationsLabel}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ApplicationSearch}"
                                                             Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Button Grid.Column="1"
                                    Width="36"
                                    Height="36"
                                    Margin="10,0,0,0"
                                    AutomationProperties.Name="{Binding RefreshLabel}"
                                    Command="{Binding RefreshApplicationsCommand}"
                                    Style="{StaticResource RefreshIconButton}">
                                <Button.Triggers>
                                    <EventTrigger RoutedEvent="Button.Click">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="RefreshIconRotation"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 From="0"
                                                                 To="360"
                                                                 Duration="0:0:1"
                                                                 FillBehavior="Stop" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Button.Triggers>
                                <Path Width="18"
                                      Height="18"
                                      Data="M129.9 292.5C143.2 199.5 223.3 128 320 128C373 128 421 149.5 455.8 184.2C456 184.4 456.2 184.6 456.4 184.8L464 192L416.1 192C398.4 192 384.1 206.3 384.1 224C384.1 241.7 398.4 256 416.1 256L544.1 256C561.8 256 576.1 241.7 576.1 224L576.1 96C576.1 78.3 561.8 64 544.1 64C526.4 64 512.1 78.3 512.1 96L512.1 149.4L500.8 138.7C454.5 92.6 390.5 64 320 64C191 64 84.3 159.4 66.6 283.5C64.1 301 76.2 317.2 93.7 319.7C111.2 322.2 127.4 310 129.9 292.6zM573.4 356.5C575.9 339 563.7 322.8 546.3 320.3C528.9 317.8 512.6 330 510.1 347.4C496.8 440.4 416.7 511.9 320 511.9C267 511.9 219 490.4 184.2 455.7C184 455.5 183.8 455.3 183.6 455.1L176 447.9L223.9 447.9C241.6 447.9 255.9 433.6 255.9 415.9C255.9 398.2 241.6 383.9 223.9 383.9L96 384C87.5 384 79.3 387.4 73.3 393.5C67.3 399.6 63.9 407.7 64 416.3L65 543.3C65.1 561 79.6 575.2 97.3 575C115 574.8 129.2 560.4 129 542.7L128.6 491.2L139.3 501.3C185.6 547.4 249.5 576 320 576C449 576 555.7 480.6 573.4 356.5z"
                                      Fill="#3771FF"
                                      RenderTransformOrigin="0.5,0.5"
                                      Stretch="Uniform">
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="RefreshIconRotation" />
                                    </Path.RenderTransform>
                                </Path>
                            </Button>
                        </Grid>

                        <Grid>
                            <ListBox MaxHeight="290"
                                     Padding="0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemsSource="{Binding ApplicationsView}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment"
                                                Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="3,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="34"
                                                    Height="34"
                                                    HorizontalAlignment="Left"
                                                    Background="#EAECF0"
                                                    CornerRadius="8">
                                                <Grid>
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               Foreground="#475467"
                                                               Text="{Binding Initial}" />
                                                    <Image Width="26"
                                                           Height="26"
                                                           Source="{Binding Icon}"
                                                           Stretch="Uniform" />
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center">
                                                <TextBlock FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="#344054"
                                                           Text="{Binding DisplayName}" />
                                                <TextBlock FontSize="11"
                                                           Foreground="#98A2B3"
                                                           Text="{Binding Id}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="2"
                                                      AutomationProperties.Name="{Binding DisplayName}"
                                                      IsChecked="{Binding IsAllowed, Mode=TwoWay}"
                                                      Style="{StaticResource ToggleSwitch}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#667085"
                                       Text="{Binding LoadingApplicationsText}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLoadingApplications}"
                                                         Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#667085"
                                       Text="{Binding NoApplicationsText}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowNoApplications}"
                                                         Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        </Grid>
    </Grid>
</Window>
