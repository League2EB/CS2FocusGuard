<Window x:Class="CS2FocusGuard.App.UpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding AppTitle}"
        Width="400"
        Height="215"
        MinWidth="400"
        MinHeight="215"
        MaxWidth="400"
        MaxHeight="215"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6FA">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock FontSize="17"
                   FontWeight="SemiBold"
                   Foreground="#101828"
                   Text="{Binding TitleText}" />
        <TextBlock Grid.Row="1"
                   Margin="0,12,0,0"
                   Foreground="#475467"
                   TextWrapping="Wrap"
                   Text="{Binding MessageText}" />
        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="80"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="Later_Click"
                    Content="{Binding LaterText}" />
            <Button Width="104"
                    Height="32"
                    Background="#3771FF"
                    BorderBrush="#3771FF"
                    Foreground="White"
                    Click="UpdateNow_Click"
                    Content="{Binding UpdateNowText}" />
        </StackPanel>
    </Grid>
</Window>
