<Window x:Class="CS2FocusGuard.App.UpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding AppTitle}"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI"
        FontSize="{DynamicResource Metric.Font.Body}"
        TextOptions.TextFormattingMode="Display">
    <Grid Width="{DynamicResource Metric.Dialog.AvailableWidth}"
          Height="{DynamicResource Metric.Dialog.AvailableHeight}"
          Margin="{DynamicResource Metric.Padding.Dialog}"
          UseLayoutRounding="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock FontSize="{DynamicResource Metric.Font.DialogTitle}"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Text="{Binding TitleText}" />
        <TextBlock Grid.Row="1"
                   Margin="{DynamicResource Metric.Margin.DialogMessage}"
                   Foreground="{DynamicResource BodyTextBrush}"
                   TextWrapping="Wrap"
                   Text="{Binding MessageText}" />
        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button x:Name="LaterButton"
                    Width="{DynamicResource Metric.Control.LaterButtonWidth}"
                    Height="{DynamicResource Metric.Control.ButtonHeight}"
                    Margin="{DynamicResource Metric.Margin.DialogButtonGap}"
                    Click="Later_Click"
                    Content="{Binding LaterText}" />
            <Button x:Name="UpdateNowButton"
                    Width="{DynamicResource Metric.Control.UpdateButtonWidth}"
                    Height="{DynamicResource Metric.Control.ButtonHeight}"
                    Click="UpdateNow_Click"
                    Content="{Binding UpdateNowText}"
                    Style="{DynamicResource PrimaryButton}" />
        </StackPanel>
    </Grid>
</Window>
